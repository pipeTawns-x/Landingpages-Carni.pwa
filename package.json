{
  "name": "carni-node-practice",
  "version": "1.0.0",
  "description": "MVP frontend de Carni-mvp con capa de práctica EBAC Node.js Phase 1 aislada del flujo PWA/Vite",
  "author": "Felipe Eduardo Torres Aguilar",
  "main": "app.js",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3002",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "ts:check": "tsc --noEmit",
    "ts:build": "tsc",
    "api:dev": "tsx server/app.ts",
    "ebac": "node app.js",
    "ebac:check": "npm run ebac && npm run build",
    "serve:static": "serve . -l 3000",
    "start": "npm run serve:static"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "axios": "^1.12.2",
    "chalk": "^4.1.2",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "serve": "^14.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.1.12"
  },
  "license": "MIT"
}
