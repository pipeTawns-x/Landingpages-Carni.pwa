{
  "name": "carniceria-pwa",
  "version": "1.2.0",
  "description": "Sistema completo de e-commerce para carnicería con PWA, programa de afiliados, panel administrativo y reportes en tiempo real",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --emptyOutDir",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "husky install",
    "deploy:preview": "npm run build && npx serve dist -p 4173",
    "deploy:analyze": "npm run build && npx vite-bundle-analyzer dist"
  },
  "keywords": [
    "carniceria",
    "pwa",
    "ecommerce",
    "carne-premium",
    "afiliados",
    "admin-dashboard",
    "ventas-online",
    "productos-frescos",
    "misericordia",
    "typescript",
    "vite",
    "tailwindcss",
    "progressive-web-app"
  ],
  "author": {
    "name": "Carnicería El Señor de La Misericordia",
    "email": "contacto@carniceriasenormisericordia.com",
    "url": "https://carniceriasenormisericordia.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pipeTawns-x/Landingpages-Carni.pwa.git",
    "directory": "/"
  },
  "bugs": {
    "url": "https://github.com/pipeTawns-x/Landingpages-Carni.pwa/issues"
  },
  "homepage": "https://pipetawns-x.github.io/Landingpages-Carni.pwa",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.13",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "sass": "^1.77.6",
    "serve": "^14.2.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^5.4.20",
    "vite-plugin-pwa": "^0.17.5",
    "vitest": "^1.6.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "last 2 versions",
      "since 2020"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{css,scss,md}": [
      "prettier --write"
    ]
  }
}